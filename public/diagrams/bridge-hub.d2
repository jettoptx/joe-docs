direction: down
layout: elk
theme: 200
sketch: true

classes: {
  node-orange: {
    style: {
      fill: "#1c1007"
      stroke: "#f97316"
      stroke-width: 2
      border-radius: 8
      font-color: "#fb923c"
    }
  }
  node-blue: {
    style: {
      fill: "#0a1028"
      stroke: "#60a5fa"
      stroke-width: 2
      border-radius: 8
      font-color: "#93c5fd"
    }
  }
  node-red: {
    style: {
      fill: "#1a0a0a"
      stroke: "#f43f5e"
      stroke-width: 2
      border-radius: 8
      font-color: "#fb7185"
    }
  }
  node-green: {
    style: {
      fill: "#0a1a0a"
      stroke: "#22c55e"
      stroke-width: 2
      border-radius: 8
      font-color: "#4ade80"
    }
  }
  node-yellow: {
    style: {
      fill: "#1a1508"
      stroke: "#eab308"
      stroke-width: 2
      border-radius: 8
      font-color: "#fbbf24"
    }
  }
  node-gray: {
    style: {
      fill: "#1a1a1a"
      stroke: "#888"
      stroke-width: 1
      border-radius: 8
      font-color: "#aaa"
    }
  }
}

OPTX: "OPTX" { class: node-blue }
AARON: "AARON" { class: node-yellow }
SOL: "SOL" { class: node-blue }
EVM: "EVM" { class: node-red }
XRPL: "XRPL" { class: node-red }
LZ: "LayerZero" { class: node-blue }

OPTX -> AARON
AARON -> SOL
AARON -> EVM
AARON -> XRPL
AARON -> LZ

