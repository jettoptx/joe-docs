direction: down
layout: elk
theme: 200
sketch: true

classes: {
  core: {
    style: {
      fill: "#1c1007"
      stroke: "#f97316"
      stroke-width: 2
      border-radius: 10
      font-color: "#f97316"
      shadow: true
    }
  }
  service: {
    style: {
      fill: "#1a1a1a"
      stroke: "#3b82f6"
      stroke-width: 1
      border-radius: 8
      font-color: "#93c5fd"
    }
  }
  chain: {
    shape: hexagon
    style: {
      fill: "#0a1a0a"
      stroke: "#22c55e"
      stroke-width: 2
      font-color: "#4ade80"
    }
  }
  db: {
    shape: cylinder
    style: {
      fill: "#1a1508"
      stroke: "#f59e0b"
      stroke-width: 1
      font-color: "#fbbf24"
    }
  }
  mesh: {
    style: {
      fill: "#0a141a"
      stroke: "#06b6d4"
      stroke-width: 2
      border-radius: 10
      font-color: "#22d3ee"
    }
  }
}

user: "User (Eyes + Wallet)" {
  shape: person
  style: {
    fill: "#1a1a1a"
    stroke: "#93c5fd"
    font-color: "#93c5fd"
  }
}

frontend: "Frontend (Next.js)" {
  class: service
}

aaron: "AARON Router" {
  class: core
}

spacetimedb: "SpacetimeDB" {
  class: db
}

joe: "JOE (Agent)" {
  class: core
}

hedgehog: "HEDGEHOG (Brain)" {
  class: mesh
}

solana: "Solana (Chain)" {
  class: chain
}

sqlite: "SQLite (API audit)" {
  class: db
}

user -> frontend: "eyes + wallet" {
  style.stroke: "#93c5fd"
}

frontend -> aaron: "gaze proof" {
  style.stroke: "#f97316"
}

aaron -> spacetimedb: "store gaze sessions" {
  style.stroke: "#f59e0b"
}

aaron -> joe: "validates" {
  style.stroke: "#f97316"
}

joe <-> hedgehog: "routes AI" {
  style.stroke: "#06b6d4"
}

joe -> solana: "attestation PDA" {
  style.stroke: "#22c55e"
}

hedgehog -> sqlite: "API tracking" {
  style.stroke: "#f59e0b"
}

frontend -> solana: "OPTX minted" {
  style.stroke: "#22c55e"
}

# Luke 18:31
