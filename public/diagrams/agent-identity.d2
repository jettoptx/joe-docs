direction: down
layout: elk
theme: 200
sketch: true

classes: {
  node-orange: {
    style: {
      fill: "#1c1007"
      stroke: "#f97316"
      stroke-width: 2
      border-radius: 8
      font-color: "#fb923c"
    }
  }
  node-blue: {
    style: {
      fill: "#0a1028"
      stroke: "#60a5fa"
      stroke-width: 2
      border-radius: 8
      font-color: "#93c5fd"
    }
  }
  node-red: {
    style: {
      fill: "#1a0a0a"
      stroke: "#f43f5e"
      stroke-width: 2
      border-radius: 8
      font-color: "#fb7185"
    }
  }
  node-green: {
    style: {
      fill: "#0a1a0a"
      stroke: "#22c55e"
      stroke-width: 2
      border-radius: 8
      font-color: "#4ade80"
    }
  }
  node-yellow: {
    style: {
      fill: "#1a1508"
      stroke: "#eab308"
      stroke-width: 2
      border-radius: 8
      font-color: "#fbbf24"
    }
  }
  node-gray: {
    style: {
      fill: "#1a1a1a"
      stroke: "#888"
      stroke-width: 1
      border-radius: 8
      font-color: "#aaa"
    }
  }
}

SOUL: "SOUL" { class: node-yellow }
Hermes: "Hermes" { class: node-yellow }
NFT: "NFT" { class: node-yellow }
Solana: "Solana" { class: node-yellow }
xSPECTAR: "xSPECTAR" { class: node-yellow }
XRPL: "XRPL" { class: node-yellow }
Gaze: "Gaze" { class: node-yellow }
AARON: "AARON" { class: node-yellow }

PDA: "PDA" { class: node-blue }
Skills: "Skills" { class: node-blue }
Rep: "Rep" { class: node-blue }
Wallets: "Wallets" { class: node-blue }

SOL: "SOL" { class: node-red }
ETH: "ETH" { class: node-red }
MPX: "MPX" { class: node-red }
XRP: "XRP" { class: node-red }

SOUL -> Hermes
NFT -> Solana
xSPECTAR -> XRPL
Gaze -> AARON

Solana -> PDA

PDA -> Skills
PDA -> Rep
PDA -> Wallets

Wallets -> SOL
Wallets -> ETH
Wallets -> MPX
Wallets -> XRP

